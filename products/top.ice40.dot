n9 [ shape=diamond, label="ps2_listener.ps2_data", color="black", fontcolor="black"];
n10 [ shape=diamond, label="ps2_listener.reset", color="black", fontcolor="black"];
n11 [ shape=octagon, label="rst_n", color="black", fontcolor="black"];
c12 [ shape=record, label="{{}|computer\n$scopeinfo|{}}",  ];
c13 [ shape=record, label="{{}|computer.cpu\n$scopeinfo|{}}",  ];
c14 [ shape=record, label="{{}|computer.cpu.calculations\n$scopeinfo|{}}",  ];
c15 [ shape=record, label="{{}|computer.memory\n$scopeinfo|{}}",  ];
