c17 [ shape=record, label="{{}|computer.memory.screen\n$scopeinfo|{}}",  ];
c18 [ shape=record, label="{{}|computer.rom\n$scopeinfo|{}}",  ];
c19 [ shape=record, label="{{}|ps2_decoder\n$scopeinfo|{}}",  ];
c20 [ shape=record, label="{{}|ps2_listener\n$scopeinfo|{}}",  ];
c21 [ shape=record, label="{{}|ps2_listener.reverser_b1\n$scopeinfo|{}}",  ];
c22 [ shape=record, label="{{}|ps2_listener.reverser_b2\n$scopeinfo|{}}",  ];
c23 [ shape=record, label="{{}|ps2_listener.reverser_b3\n$scopeinfo|{}}",  ];
