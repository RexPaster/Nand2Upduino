n5 [ shape=diamond, label="computer.reset", color="black", fontcolor="black"];
n6 [ shape=octagon, label="ps2_clk", color="black", fontcolor="black"];
n7 [ shape=octagon, label="ps2_data", color="black", fontcolor="black"];
