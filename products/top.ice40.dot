digraph "top" {
label="top";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="clk_12mhz", color="black", fontcolor="black"];
n2 [ shape=diamond, label="computer.clock", color="black", fontcolor="black"];
n3 [ shape=diamond, label="computer.cpu.clock", color="black", fontcolor="black"];
